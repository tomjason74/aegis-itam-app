<w:document xmlns:wpc="http://schemas.microsoft.com/office/word/2010/wordprocessingCanvas" xmlns:cx="http://schemas.microsoft.com/office/drawing/2014/chartex" xmlns:cx1="http://schemas.microsoft.com/office/drawing/2015/9/8/chartex" xmlns:cx2="http://schemas.microsoft.com/office/drawing/2015/10/21/chartex" xmlns:cx3="http://schemas.microsoft.com/office/drawing/2016/5/9/chartex" xmlns:cx4="http://schemas.microsoft.com/office/drawing/2016/5/10/chartex" xmlns:cx5="http://schemas.microsoft.com/office/drawing/2016/5/11/chartex" xmlns:cx6="http://schemas.microsoft.com/office/drawing/2016/5/12/chartex" xmlns:cx7="http://schemas.microsoft.com/office/drawing/2016/5/13/chartex" xmlns:cx8="http://schemas.microsoft.com/office/drawing/2016/5/14/chartex" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:aink="http://schemas.microsoft.com/office/drawing/2016/ink" xmlns:am3d="http://schemas.microsoft.com/office/drawing/2017/model3d" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:oel="http://schemas.microsoft.com/office/2019/extlst" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:wp14="http://schemas.microsoft.com/office/word/2010/wordprocessingDrawing" xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" xmlns:w10="urn:schemas-microsoft-com:office:word" xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main" xmlns:w14="http://schemas.microsoft.com/office/word/2010/wordml" xmlns:w15="http://schemas.microsoft.com/office/word/2012/wordml" xmlns:w16cex="http://schemas.microsoft.com/office/word/2018/wordml/cex" xmlns:w16cid="http://schemas.microsoft.com/office/word/2016/wordml/cid" xmlns:w16="http://schemas.microsoft.com/office/word/2018/wordml" xmlns:w16du="http://schemas.microsoft.com/office/word/2023/wordml/word16du" xmlns:w16sdtdh="http://schemas.microsoft.com/office/word/2020/wordml/sdtdatahash" xmlns:w16sdtfl="http://schemas.microsoft.com/office/word/2024/wordml/sdtformatlock" xmlns:w16se="http://schemas.microsoft.com/office/word/2015/wordml/symex" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 w15 w16se w16cid w16 w16cex w16sdtdh w16sdtfl w16du wp14"><w:body><w:p w14:paraId="3EC36F66" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Deliverable 5: Architecture Decision Records (ADRs)</w:t></w:r></w:p><w:p w14:paraId="6A956FE6" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Company:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Aegis Health Partners</w:t></w:r></w:p><w:p w14:paraId="01F2AE37" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>ADR-001: Event-Driven Architecture for Integrations</w:t></w:r></w:p><w:p w14:paraId="5612176C" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Title:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Use Kafka for Event-Driven Integration (BambooHR/Coupa)</w:t></w:r></w:p><w:p w14:paraId="0F1960DB" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Status:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Accepted</w:t></w:r></w:p><w:p w14:paraId="5BA57B23" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Context:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Synchronous API polling against BambooHR and Coupa is inefficient and delays onboarding. Aegis Health requires near real-time provisioning for telehealth doctors.</w:t></w:r></w:p><w:p w14:paraId="7671D5CA" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Decision:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Implement an event-driven architecture. BambooHR will send webhooks to our API, which immediately publishes a </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00545A3C"><w:t>DoctorCreated</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00545A3C"><w:t> or </w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="00545A3C"><w:t>DoctorTerminated</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="00545A3C"><w:t> event to Kafka. Downstream services (Offboarding, Sync) will consume these events.</w:t></w:r></w:p><w:p w14:paraId="08238BB1" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Consequences:</w:t></w:r></w:p><w:p w14:paraId="56B2A897" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:i/><w:iCs/></w:rPr><w:t>Positive:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Decoupled architecture, highly scalable, handles burst terminations without crashing.</w:t></w:r></w:p><w:p w14:paraId="1EFA97E7" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:i/><w:iCs/></w:rPr><w:t>Negative:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Eventual consistency, requires Kafka infrastructure management.</w:t></w:r></w:p><w:p w14:paraId="0EA233BD" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>ADR-002: Polyglot Persistence</w:t></w:r></w:p><w:p w14:paraId="7FA7A3B0" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Title:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Separate Core Asset Data and Compliance Documents</w:t></w:r></w:p><w:p w14:paraId="5D3F8275" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Status:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Accepted</w:t></w:r></w:p><w:p w14:paraId="687CB584" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Context:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Core asset data is highly relational. However, HIPAA wipe certificates and PDF Acceptable Use Policies are unstructured and bulky.</w:t></w:r></w:p><w:p w14:paraId="134C8231" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Decision:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Use PostgreSQL for core asset management (ACID compliance) and MongoDB for storing unstructured compliance documents and raw JSON payloads from MDM telemetry.</w:t></w:r></w:p><w:p w14:paraId="792B413A" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Consequences:</w:t></w:r></w:p><w:p w14:paraId="0B724D74" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:i/><w:iCs/></w:rPr><w:t>Positive:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Optimal storage and retrieval for both data types.</w:t></w:r></w:p><w:p w14:paraId="3B120686" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:i/><w:iCs/></w:rPr><w:t>Negative:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Operational complexity of managing two different database clusters.</w:t></w:r></w:p><w:p w14:paraId="3D91230A" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>ADR-003: API Gateway Selection</w:t></w:r></w:p><w:p w14:paraId="03FA00BE" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Title:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Use Kong as API Gateway</w:t></w:r></w:p><w:p w14:paraId="28FB1ECA" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Status:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Accepted</w:t></w:r></w:p><w:p w14:paraId="44D8F3D7" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Context:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Aegis needs rate limiting, JWT validation, and routing for web and mobile apps.</w:t></w:r></w:p><w:p w14:paraId="520F4B62" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Decision:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Deploy Kong API Gateway on Kubernetes.</w:t></w:r></w:p><w:p w14:paraId="2FCBC4FF" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Consequences:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Avoids vendor lock-in with AWS API Gateway, allows rich plugin ecosystem for custom authentication headers required by legacy clinical systems.</w:t></w:r></w:p><w:p w14:paraId="37512EAC" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:lastRenderedPageBreak/><w:t>ADR-004: Workflow Orchestration</w:t></w:r></w:p><w:p w14:paraId="407853A0" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Title:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Use Temporal for Doctor Offboarding Workflows</w:t></w:r></w:p><w:p w14:paraId="632D047A" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Status:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Accepted</w:t></w:r></w:p><w:p w14:paraId="5111B6FA" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Context:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Doctor offboarding takes days (wait for FedEx box, wait for return, wait for MDM wipe). Traditional async queues drop state if they fail.</w:t></w:r></w:p><w:p w14:paraId="2FA57BEC" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Decision:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Use Temporal to manage long-running, stateful workflows. If an offboarding workflow pauses for 7 days waiting for a FedEx package, Temporal maintains the state durably.</w:t></w:r></w:p><w:p w14:paraId="7A8FE42C" w14:textId="77777777" w:rsidR="00545A3C" w:rsidRPr="00545A3C" w:rsidRDefault="00545A3C" w:rsidP="00545A3C"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr></w:pPr><w:r w:rsidRPr="00545A3C"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Consequences:</w:t></w:r><w:r w:rsidRPr="00545A3C"><w:t> Highly resilient workflows, but requires running the Temporal server cluster.</w:t></w:r></w:p><w:p w14:paraId="63D615F0" w14:textId="77777777" w:rsidR="000B2455" w:rsidRDefault="000B2455"/><w:sectPr w:rsidR="000B2455"><w:pgSz w:w="12240" w:h="15840"/><w:pgMar w:top="1440" w:right="1440" w:bottom="1440" w:left="1440" w:header="708" w:footer="708" w:gutter="0"/><w:cols w:space="708"/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>